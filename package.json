{
  "name": "frenderer",
  "version": "0.0.1",
  "description": "A lightweight, browserless SPA renderer. Execute client-side JavaScript and return fully rendered HTML without Chromium.",
  "main": "src/index.js",
  "bin": {
    "frenderer": "src/cli.js"
  },
  "type": "commonjs",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "node --test",
    "test:e2e": "node tests/e2e.test.js",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "keywords": [
    "ssr",
    "prerender",
    "spa",
    "headless-browser",
    "seo",
    "crawler",
    "rendering"
  ],
  "author": "Poran Dip",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/poran-dip/frenderer.git"
  },
  "bugs": {
    "url": "https://github.com/poran-dip/frenderer/issues"
  },
  "homepage": "https://github.com/poran-dip/frenderer#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12"
  }
}
